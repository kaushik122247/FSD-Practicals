# ------------------------------
# GitHub Actions Secrets Contract
# ------------------------------
# Add these in: GitHub repo -> Settings -> Secrets and variables -> Actions

# ===== Required: Backend deploy to EC2 =====
EC2_HOST=
EC2_USER=ubuntu
EC2_SSH_KEY="-----BEGIN OPENSSH PRIVATE KEY-----..."

# ===== Required: Firebase Hosting deploy =====
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_PROJECT_ID=

# ===== Optional: Firebase custom-domain mapping =====
FIREBASE_SITE_ID=
FIREBASE_ACCESS_TOKEN=
FIREBASE_CUSTOM_DOMAIN=app.example.com

# ===== Optional: Backend runtime tuning =====
APP_CONTAINER_NAME=exp10-backend
APP_PORT=8080
